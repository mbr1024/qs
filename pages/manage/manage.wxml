<view class="container">
  <!-- ➕ 添加鞋款 -->
  <view class="card">
    <view class="add-row">
      <input class="add-input" placeholder="输入新鞋款名称" value="{{newName}}" bindinput="onNewName" />
      <view class="add-btn" bindtap="addModel">➕ 添加</view>
    </view>
  </view>

  <view wx:if="{{models.length === 0}}" class="card"><view class="empty">暂无鞋款</view></view>

  <!-- 启用中 -->
  <view wx:for="{{models}}" wx:key="id">
    <view wx:if="{{!item.disabled}}" class="card model-card">
      <view class="model-info">
        <view wx:if="{{editingId !== item.id}}" class="model-name">{{item.name}}</view>
        <input wx:else class="edit-input" value="{{item.name}}" bindinput="onEditName" bindblur="saveEdit" bindconfirm="saveEdit" focus="{{editingId === item.id}}" />
      </view>
      <view class="model-actions">
        <view class="btn-edit" catchtap="startEdit" data-id="{{item.id}}" data-name="{{item.name}}">✏️ 编辑</view>
        <view class="btn-disable" catchtap="disableModel" data-id="{{item.id}}">🚫 禁用</view>
      </view>
    </view>
  </view>

  <!-- 已禁用 -->
  <view wx:if="{{hasDisabled}}" class="section-divider">
    <text class="divider-text">已禁用</text>
  </view>
  <view wx:for="{{models}}" wx:key="id">
    <view wx:if="{{item.disabled}}" class="card model-card disabled">
      <view class="model-info">
        <view class="model-name disabled-text">{{item.name}}</view>
      </view>
      <view class="model-actions">
        <view class="btn-enable" catchtap="enableModel" data-id="{{item.id}}">✅ 启用</view>
      </view>
    </view>
  </view>
</view>
