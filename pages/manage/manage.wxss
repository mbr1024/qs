.container { padding: 20rpx; }
.empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }

/* 添加行 */
.add-row {
  display: flex; gap: 12rpx; align-items: center;
}
.add-input {
  flex: 1; height: 72rpx; background: #f5f5f5; border-radius: 10rpx;
  padding: 0 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box;
}
.add-btn {
  height: 72rpx; line-height: 72rpx; padding: 0 32rpx;
  background: #1890ff; color: #fff; border-radius: 10rpx;
  font-size: 28rpx; font-weight: 500; white-space: nowrap;
}

/* 鞋款卡片 */
.model-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx !important;
}
.model-card.disabled { background: #fafafa; opacity: 0.6; }
.model-info { flex: 1; }
.model-name { font-size: 30rpx; font-weight: 500; color: #333; }
.model-name.disabled-text { color: #999; text-decoration: line-through; }
.edit-input {
  height: 60rpx; background: #fff; border: 2rpx solid #1890ff;
  border-radius: 8rpx; padding: 0 16rpx; font-size: 28rpx; box-sizing: border-box;
}
.model-actions { display: flex; gap: 12rpx; }
.btn-edit {
  font-size: 24rpx; color: #1890ff; padding: 8rpx 20rpx;
  border: 1rpx solid #1890ff; border-radius: 6rpx;
}
.btn-disable {
  font-size: 24rpx; color: #ff4d4f; padding: 8rpx 20rpx;
  border: 1rpx solid #ff4d4f; border-radius: 6rpx;
}
.btn-enable {
  font-size: 24rpx; color: #52c41a; padding: 8rpx 20rpx;
  border: 1rpx solid #52c41a; border-radius: 6rpx;
}

/* 禁用分隔线 */
.section-divider {
  display: flex; align-items: center; margin: 24rpx 0 16rpx;
}
.divider-text { font-size: 24rpx; color: #999; margin-right: 16rpx; }
.section-divider::after {
  content: ''; flex: 1; height: 1rpx; background: #e8e8e8;
}
