.container { padding: 20rpx; }
.sub-tabs { display: flex; gap: 0; margin-bottom: 20rpx; background: #fff; border-radius: 12rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.sub-tab {
  flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; font-weight: 500;
  color: #999; border-bottom: 4rpx solid transparent;
}
.sub-tab.active { color: #1890ff; border-bottom-color: #1890ff; background: #f0f8ff; }
.type-btns { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.type-btn {
  flex: 1; height: 72rpx; line-height: 72rpx; text-align: center;
  border-radius: 10rpx; font-size: 28rpx; font-weight: 500;
  background: #f5f5f5; color: #666; border: 2rpx solid transparent;
}
.type-btn.active { background: #e6f7ff; color: #1890ff; border-color: #1890ff; }
.form-row { display: flex; gap: 16rpx; }
.form-group { flex: 1; margin-bottom: 16rpx; }
.form-label { display: block; font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.form-input {
  height: 72rpx; background: #fff; border: 1rpx solid #d9d9d9;
  border-radius: 10rpx; padding: 0 20rpx; color: #333; font-size: 28rpx;
}
.picker-val {
  height: 72rpx; line-height: 72rpx; background: #fff; border: 1rpx solid #d9d9d9;
  border-radius: 10rpx; padding: 0 20rpx; color: #333; font-size: 28rpx;
}
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #333; }
.size-grid { background: #fff; border-radius: 10rpx; overflow: hidden; }
.sg-header {
  display: flex; align-items: center; padding: 12rpx 0; border-bottom: 2rpx solid #eee;
  font-size: 22rpx; color: #999; font-weight: 600;
}
.sg-row { display: flex; align-items: center; padding: 10rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.sg-row:last-child { border-bottom: none; }
.sg-h-num, .sg-num { width: 70rpx; text-align: center; font-size: 26rpx; }
.sg-num { color: #333; font-weight: 500; }
.sg-h-stock, .sg-stock { width: 80rpx; text-align: center; font-size: 24rpx; color: #ccc; }
.sg-h-qty { flex: 1; text-align: center; font-size: 22rpx; }
.sg-input {
  flex: 1; height: 52rpx; background: #f9f9f9; border: 1rpx solid #e8e8e8;
  border-radius: 6rpx; margin: 0 4rpx; font-size: 26rpx; color: #333; text-align: center;
}
.sg-def { border-color: #ffccc7; }
.c-blue { color: #1890ff; font-weight: 600; }
.c-green { color: #52c41a; font-weight: 600; }
.c-purple { color: #722ed1; font-weight: 600; }
.empty { text-align: center; padding: 40rpx 0; color: #999; font-size: 26rpx; }
.rec-item {
  display: flex; align-items: center; padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx;
}
.rec-item:last-child { border-bottom: none; }
.rec-item.voided { opacity: 0.5; }
.ri-left { flex: 1; display: flex; align-items: center; gap: 8rpx; }
.ri-type { font-size: 22rpx; padding: 4rpx 10rpx; border-radius: 6rpx; font-weight: 500; }
.ri-type.t-in { background: #e6f7ff; color: #1890ff; }
.ri-type.t-mid { background: #f6ffed; color: #52c41a; }
.ri-type.t-out { background: #fff7e6; color: #faad14; }
.ri-model { font-size: 22rpx; color: #666; background: #f0f0f0; padding: 2rpx 8rpx; border-radius: 4rpx; }
.ri-size { font-size: 22rpx; color: #722ed1; }
.ri-void { font-size: 20rpx; color: #ff4d4f; background: #fff2f0; padding: 2rpx 8rpx; border-radius: 4rpx; }
.ri-qty { font-size: 28rpx; font-weight: 700; color: #1890ff; margin: 0 12rpx; }
.ri-date { font-size: 22rpx; color: #999; }
.qty-void { color: #ccc; text-decoration: line-through; }
.btn-void {
  font-size: 22rpx; color: #ff4d4f; padding: 6rpx 12rpx;
  border: 1rpx solid #ff4d4f; border-radius: 6rpx; margin-left: 8rpx;
}
