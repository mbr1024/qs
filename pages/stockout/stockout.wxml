<view class="container">
  <view class="section-title">🚚 出货</view>
  <view class="card">
    <view class="form-row">
      <view class="form-group">
        <text class="form-label">鞋款型号</text>
        <input class="form-input" placeholder="输入鞋款" value="{{model}}" bindinput="onModelInput" bindconfirm="loadModelStock" />
      </view>
      <view class="form-group">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view class="picker-val">{{date}}</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">各尺码出货量（留空=不出货）</view>
    <view class="size-grid">
      <view class="size-header">
        <text class="sh-num">尺码</text>
        <text class="sh-stock">库存</text>
        <text class="sh-input">出货</text>
      </view>
      <view wx:for="{{rows}}" wx:key="size" class="size-row">
        <text class="sr-num">{{item.size}}</text>
        <text class="sr-stock {{item.qty > 0 ? 'has-purple' : ''}}">{{item.qty || '-'}}</text>
        <input class="sr-input" type="number" placeholder="0" data-size="{{item.size}}" bindinput="onQtyInput" />
      </view>
    </view>
    <view class="btn-primary" style="margin-top:20rpx" bindtap="submitBatch">批量出货</view>
  </view>

  <view class="card">
    <view class="card-title">出货记录</view>
    <view wx:if="{{list.length === 0}}" class="empty">暂无出货记录</view>
    <view wx:for="{{list}}" wx:key="id" class="record-item">
      <view class="ri-left">
        <view class="ri-main">
          出货
          <text wx:if="{{item.shoe_model}}" class="tag tag-model">{{item.shoe_model}}</text>
          <text wx:if="{{item.shoe_size}}" class="tag tag-size">{{item.shoe_size}}码</text>
        </view>
        <view class="ri-sub">{{item.date}}</view>
      </view>
      <view class="ri-right">
        <view class="ri-qty">{{item.qtyText}}</view>
        <view class="btn-danger" bindtap="onDelete" data-id="{{item.id}}">删</view>
      </view>
    </view>
  </view>
</view>
