.container { padding: 20rpx; }
.form-row { display: flex; gap: 16rpx; }
.form-group { flex: 1; margin-bottom: 20rpx; }
.form-label { display: block; font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.form-input {
  height: 72rpx; background: #fff; border: 1rpx solid #d9d9d9;
  border-radius: 10rpx; padding: 0 20rpx; color: #333; font-size: 28rpx;
}
.picker-val {
  height: 72rpx; line-height: 72rpx; background: #fff; border: 1rpx solid #d9d9d9;
  border-radius: 10rpx; padding: 0 20rpx; color: #333; font-size: 28rpx;
}
.type-btns { display: flex; gap: 16rpx; }
.type-btn {
  flex: 1; height: 72rpx; line-height: 72rpx; text-align: center;
  border-radius: 10rpx; font-size: 28rpx; font-weight: 500;
  background: #f5f5f5; color: #666; border: 2rpx solid transparent;
}
.type-btn.active {
  background: #e6f7ff; color: #1890ff; border-color: #1890ff;
}
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #333; }
.size-grid { background: #fff; border-radius: 10rpx; overflow: hidden; }
.size-header {
  display: flex; padding: 12rpx 0; border-bottom: 2rpx solid #eee;
  font-size: 22rpx; color: #999; font-weight: 500;
}
.size-row {
  display: flex; align-items: center; padding: 10rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.size-row:last-child { border-bottom: none; }
.sh-num, .sr-num { width: 120rpx; text-align: center; font-size: 26rpx; }
.sr-num { color: #333; font-weight: 500; }
.sh-input { flex: 1; text-align: center; font-size: 24rpx; }
.sr-input {
  flex: 1; height: 56rpx; background: #f9f9f9; border: 1rpx solid #e8e8e8;
  border-radius: 6rpx; margin: 0 20rpx; font-size: 26rpx; color: #333; text-align: center;
}
.record-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.record-item:last-child { border-bottom: none; }
.ri-left { flex: 1; }
.ri-main { font-size: 28rpx; font-weight: 500; margin-bottom: 4rpx; color: #333; }
.ri-sub { font-size: 22rpx; color: #999; }
.ri-right { display: flex; align-items: center; gap: 16rpx; }
.ri-qty { font-size: 32rpx; font-weight: 700; color: #1890ff; }
