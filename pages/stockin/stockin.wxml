<view class="container">
  <view class="section-title">📦 进货</view>
  <view class="card">
    <view class="form-group">
      <text class="form-label">类型</text>
      <view class="type-btns">
        <view class="type-btn {{typeIdx === 0 ? 'active' : ''}}" bindtap="onTypeTap" data-idx="0">中底</view>
        <view class="type-btn {{typeIdx === 1 ? 'active' : ''}}" bindtap="onTypeTap" data-idx="1">大底</view>
      </view>
    </view>
    <view class="form-row">
      <view class="form-group">
        <text class="form-label">供应商</text>
        <input class="form-input" placeholder="供应商" value="{{supplier}}" bindinput="onSupplierInput" />
      </view>
      <view class="form-group">
        <text class="form-label">鞋款型号</text>
        <input class="form-input" placeholder="如 A001" value="{{model}}" bindinput="onModelInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-val">{{date}}</view>
      </picker>
    </view>
  </view>

  <view class="card">
    <view class="card-title">各尺码数量（留空=不录入）</view>
    <view class="size-grid">
      <view class="size-header">
        <text class="sh-num">尺码</text>
        <text class="sh-input">数量</text>
      </view>
      <view wx:for="{{sizes}}" wx:key="*this" class="size-row">
        <text class="sr-num">{{item}}</text>
        <input class="sr-input" type="number" placeholder="0" data-size="{{item}}" bindinput="onSizeQtyInput" />
      </view>
    </view>
    <view class="btn-primary" style="margin-top:20rpx" bindtap="submitBatch">批量录入</view>
  </view>

  <view class="card">
    <view class="card-title">进货记录</view>
    <view wx:if="{{list.length === 0}}" class="empty">暂无进货记录</view>
    <view wx:for="{{list}}" wx:key="id" class="record-item">
      <view class="ri-left">
        <view class="ri-main">
          <text class="tag {{item.type === 'midsole' ? 'tag-midsole' : 'tag-outsole'}}">{{item.type === 'midsole' ? '中底' : '大底'}}</text>
          <text wx:if="{{item.shoe_model}}" class="tag tag-model">{{item.shoe_model}}</text>
          <text wx:if="{{item.shoe_size}}" class="tag tag-size">{{item.shoe_size}}码</text>
          {{item.supplier}}
        </view>
        <view class="ri-sub">{{item.date}}</view>
      </view>
      <view class="ri-right">
        <view class="ri-qty">{{item.qtyText}}</view>
        <view class="btn-danger" bindtap="onDelete" data-id="{{item.id}}">删</view>
      </view>
    </view>
  </view>
</view>
