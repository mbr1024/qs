.container { padding: 20rpx; }
.add-btn {
  background: #1890ff;
  color: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.add-card {
  border: 2rpx solid #1890ff;
  margin-bottom: 20rpx;
}
.form-group { margin-bottom: 16rpx; }
.form-label { display: block; font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.form-input {
  height: 72rpx;
  background: #fff;
  border: 1rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 0 20rpx;
  color: #333;
  font-size: 28rpx;
}
.form-btns {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}
.btn-cancel {
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
}
.btn-confirm {
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #fff;
  background: #1890ff;
}
.model-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #f0f0f0;
}
.model-card.disabled {
  background: #fafafa;
  opacity: 0.7;
}
.model-info { flex: 1; }
.model-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.model-name.disabled-text {
  color: #999;
  text-decoration: line-through;
}
.edit-input {
  height: 60rpx;
  background: #fff;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
}
.model-actions {
  display: flex;
  gap: 12rpx;
}
.btn-edit {
  font-size: 24rpx;
  color: #1890ff;
  padding: 8rpx 20rpx;
  border: 1rpx solid #1890ff;
  border-radius: 6rpx;
}
.btn-disable {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ff4d4f;
  border-radius: 6rpx;
}
.btn-enable {
  font-size: 24rpx;
  color: #52c41a;
  padding: 8rpx 20rpx;
  border: 1rpx solid #52c41a;
  border-radius: 6rpx;
}
.section-divider {
  display: flex;
  align-items: center;
  margin: 24rpx 0 16rpx;
}
.divider-text {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}
.section-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}
