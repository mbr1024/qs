.container { padding: 20rpx; }
.filter-bar {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.sub-tabs { display: flex; gap: 0; margin-bottom: 16rpx; }
.sub-tab {
  flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; font-weight: 500;
  color: #999; border-bottom: 4rpx solid transparent;
}
.sub-tab.active { color: #1890ff; border-bottom-color: #1890ff; }
.date-filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.date-btn {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
}
.date-sep { color: #999; font-size: 24rpx; }
.btn-reset {
  padding: 0 20rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  border-radius: 8rpx;
}
.quick-dates {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.qd-btn {
  flex: 1;
  text-align: center;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.qd-btn.active {
  color: #1890ff;
  background: #e6f7ff;
  border-color: #1890ff;
  font-weight: 500;
}
/* 卡片 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.total-tag { font-size: 20rpx; font-weight: 400; color: #999; }

/* 合计栏 */
.total-bar {
  display: flex; gap: 20rpx; margin-bottom: 16rpx;
  padding-bottom: 12rpx; border-bottom: 1rpx solid #f0f0f0;
}
.tb-item { font-size: 24rpx; color: #999; }
.tb-item.c-blue { color: #1890ff; font-weight: 500; }
.tb-item.c-green { color: #52c41a; font-weight: 500; }

/* 日期分组头 */
.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 4rpx 8rpx;
}
.day-date { font-size: 30rpx; font-weight: 700; color: #333; }
.day-total { font-size: 24rpx; color: #999; }

/* 段落 */
.inv-section { margin-bottom: 20rpx; }
.inv-section:last-child { margin-bottom: 0; }
.inv-label { font-size: 22rpx; font-weight: 600; margin-bottom: 12rpx; display: block; }

/* 尺码网格 */
.size-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.size-cell {
  width: calc(20% - 8rpx);
  min-width: 100rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 10rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}
.sc-size { 
  font-size: 20rpx; 
  color: #bbb; 
  background: #f0f0f0; 
  padding: 2rpx 8rpx; 
  border-radius: 4rpx; 
  margin-bottom: 2rpx;
}
.sc-qty { font-size: 28rpx; font-weight: 700; color: #1890ff; }
.sc-def { font-size: 18rpx; color: #ff4d4f; margin-top: 2rpx; }
.c-blue { color: #1890ff; background: #e6f7ff; padding: 2rpx 6rpx; border-radius: 4rpx; }
.c-green { color: #52c41a; background: #f6ffed; padding: 2rpx 6rpx; border-radius: 4rpx; }
.c-gray { color: #ccc; padding: 2rpx 6rpx; border-radius: 4rpx; }
.empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 26rpx; }
