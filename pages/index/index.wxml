<view class="container">
  <view class="section-label">今日运营</view>
  <view class="metrics">
    <view class="metric-card">
      <view class="mc-header mc-blue">入库</view>
      <view class="metric-val">{{d.today_in}}</view>
      <view class="metric-detail">
        <text class="md-item"><text class="dot dot-blue"></text>MD {{d.today_in_mid}}</text>
        <text class="md-item"><text class="dot dot-green"></text>RB {{d.today_in_out}}</text>
      </view>
    </view>
    <view class="metric-card">
      <view class="mc-header mc-purple">生产</view>
      <view class="metric-val">{{d.today_production}}</view>
      <view class="metric-detail" wx:if="{{d.today_defects > 0}}">
        <text class="md-item md-warn">不良 {{d.today_defects}}</text>
      </view>
    </view>
    <view class="metric-card">
      <view class="mc-header mc-orange">出货</view>
      <view class="metric-val">{{d.today_shipment}}</view>
    </view>
  </view>

  <!-- 当前库存 -->
  <view class="section-label">当前库存</view>
  <view class="metrics">
    <view class="metric-card">
      <view class="mc-header mc-blue">MD</view>
      <view class="metric-val">{{d.stock_mid}}</view>
    </view>
    <view class="metric-card">
      <view class="mc-header mc-green">RB</view>
      <view class="metric-val">{{d.stock_out}}</view>
    </view>
    <view class="metric-card">
      <view class="mc-header mc-purple">成品</view>
      <view class="metric-val">{{d.stock_product}}</view>
    </view>
  </view>

  <!-- 入库明细 -->
  <view class="card">
    <view class="card-title">入库明细</view>
    <view wx:if="{{d.inDetail.length > 0}}" class="data-table">
      <view class="dt-header">
        <text class="dt-col dt-name">鞋款</text>
        <text class="dt-col dt-num">MD</text>
        <text class="dt-col dt-num">RB</text>
        <text class="dt-col dt-num">合计</text>
      </view>
      <view wx:for="{{d.inDetail}}" wx:key="name" class="dt-row">
        <text class="dt-col dt-name">{{item.name}}</text>
        <text class="dt-col dt-num {{item.mid > 0 ? 'c-blue' : ''}}">{{item.mid || '-'}}</text>
        <text class="dt-col dt-num {{item.out > 0 ? 'c-green' : ''}}">{{item.out || '-'}}</text>
        <text class="dt-col dt-num dt-bold">{{item.mid + item.out}}</text>
      </view>
    </view>
    <view wx:else class="empty-sm">今日暂无入库</view>
  </view>

  <!-- 生产明细 -->
  <view class="card">
    <view class="card-title">生产明细</view>
    <view wx:if="{{d.prodDetail.length > 0}}" class="data-table">
      <view class="dt-header">
        <text class="dt-col dt-name">鞋款</text>
        <text class="dt-col dt-num">完成</text>
        <text class="dt-col dt-num">不良</text>
      </view>
      <view wx:for="{{d.prodDetail}}" wx:key="name" class="dt-row">
        <text class="dt-col dt-name">{{item.name}}</text>
        <text class="dt-col dt-num dt-bold">{{item.qty}}</text>
        <text class="dt-col dt-num {{item.def > 0 ? 'c-red' : ''}}">{{item.def || '-'}}</text>
      </view>
    </view>
    <view wx:else class="empty-sm">今日暂无生产</view>
  </view>

  <!-- 出货明细 -->
  <view class="card">
    <view class="card-title">出货明细</view>
    <view wx:if="{{d.outDetail.length > 0}}" class="data-table">
      <view class="dt-header">
        <text class="dt-col dt-name">鞋款</text>
        <text class="dt-col dt-num">数量</text>
      </view>
      <view wx:for="{{d.outDetail}}" wx:key="name" class="dt-row">
        <text class="dt-col dt-name">{{item.name}}</text>
        <text class="dt-col dt-num dt-bold">{{item.qty}}</text>
      </view>
    </view>
    <view wx:else class="empty-sm">今日暂无出货</view>
  </view>

  <!-- 成品库存 -->
  <view class="card">
    <view class="card-title">成品库存</view>
    <view wx:if="{{d.prodStock.length > 0}}" class="data-table">
      <view class="dt-header">
        <text class="dt-col dt-name">鞋款</text>
        <text class="dt-col dt-num">库存</text>
      </view>
      <view wx:for="{{d.prodStock}}" wx:key="name" class="dt-row">
        <text class="dt-col dt-name">{{item.name}}</text>
        <text class="dt-col dt-num dt-bold">{{item.qty}}</text>
      </view>
    </view>
    <view wx:else class="empty-sm">暂无成品库存</view>
  </view>
</view>
