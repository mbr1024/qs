.container { padding: 20rpx; }

/* 分区标签 */
.section-label {
  font-size: 24rpx; color: #999; font-weight: 500;
  margin-bottom: 12rpx; padding-left: 4rpx;
}

/* 指标卡片 - 3列 */
.metrics { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.metric-card {
  flex: 1; background: #fff; border-radius: 12rpx; overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); box-sizing: border-box;
}
.mc-header {
  padding: 10rpx 0; text-align: center;
  font-size: 22rpx; font-weight: 600; color: #fff;
}
.mc-blue { background: #1890ff; }
.mc-green { background: #52c41a; }
.mc-purple { background: #722ed1; }
.mc-orange { background: #fa8c16; }
.metric-val {
  font-size: 40rpx; font-weight: 700; color: #333;
  text-align: center; padding: 16rpx 0 8rpx;
}
.metric-detail {
  display: flex; justify-content: center; gap: 12rpx;
  padding: 0 8rpx 14rpx;
}
.md-item {
  font-size: 20rpx; color: #999; display: flex; align-items: center; gap: 4rpx;
}
.md-warn { color: #ff4d4f; }
.dot {
  display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%;
}
.dot-blue { background: #1890ff; }
.dot-green { background: #52c41a; }

/* 卡片 */
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; color: #333; }

/* 数据表格 */
.data-table { }
.dt-header {
  display: flex; padding: 12rpx 0; border-bottom: 2rpx solid #f0f0f0;
}
.dt-header .dt-col { font-size: 22rpx; color: #999; font-weight: 500; }
.dt-row {
  display: flex; padding: 14rpx 0; border-bottom: 1rpx solid #f8f8f8;
}
.dt-row:last-child { border-bottom: none; }
.dt-col { font-size: 26rpx; color: #333; }
.dt-name { flex: 2; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.dt-num { flex: 1; text-align: center; }
.dt-bold { font-weight: 700; }
.c-blue { color: #1890ff; }
.c-green { color: #52c41a; }
.c-red { color: #ff4d4f; }
