<view class="container">
  <view wx:if="{{list.length === 0}}" class="card"><view class="empty">暂无库存</view></view>
  <view wx:for="{{list}}" wx:key="name" class="card">
    <view class="card-title">
      {{item.name}}
      <text class="total-tag">MD {{item.midTotal}}  RB {{item.outTotal}}  成品 {{item.prodTotal}}</text>
    </view>
    <view class="inv-section" wx:if="{{item.midsole.length > 0}}">
      <text class="inv-label c-blue">🧱 MD</text>
      <view class="size-grid">
        <view wx:for="{{item.midsole}}" wx:for-item="sz" wx:key="size" class="size-cell">
          <text class="sc-size">{{sz.size}}</text>
          <text class="sc-qty">{{sz.qty}}</text>
        </view>
      </view>
    </view>
    <view class="inv-section" wx:if="{{item.outsole.length > 0}}">
      <text class="inv-label c-green">👟 RB</text>
      <view class="size-grid">
        <view wx:for="{{item.outsole}}" wx:for-item="sz" wx:key="size" class="size-cell">
          <text class="sc-size">{{sz.size}}</text>
          <text class="sc-qty c-green">{{sz.qty}}</text>
        </view>
      </view>
    </view>
    <view class="inv-section" wx:if="{{item.product.length > 0}}">
      <text class="inv-label c-purple">📦 成品</text>
      <view class="size-grid">
        <view wx:for="{{item.product}}" wx:for-item="sz" wx:key="size" class="size-cell">
          <text class="sc-size">{{sz.size}}</text>
          <text class="sc-qty c-purple">{{sz.qty}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{item.midsole.length === 0 && item.outsole.length === 0 && item.product.length === 0}}" class="empty-sm">暂无库存</view>
  </view>
</view>
